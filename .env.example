# Postgres (matches compose.yaml — host port 5433 to avoid clashing with an
# existing postgres already bound to 5432 on this machine)
DATABASE_URL=postgres://mtg:mtg_dev_password@localhost:5433/mtg_rules?sslmode=disable

# Embedding provider — pick one and keep dimensions consistent with init.sql's vector(1536)
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# LLM used to generate the final answer
LLM_API_KEY=
LLM_MODEL=claude-sonnet-5

# Data sources (see docs/DATA_SOURCES.md for how these are used)
SCRYFALL_BULK_DATA_URL=https://api.scryfall.com/bulk-data
# The Comprehensive Rules .txt filename is date-stamped and changes with each update
# (e.g. MagicCompRules%2020260619.txt). Check https://magic.wizards.com/en/rules for
# the current link before hardcoding this — see docs/DATA_SOURCES.md.
COMPREHENSIVE_RULES_URL=https://media.wizards.com/2026/downloads/MagicCompRules%2020260619.txt

# Server (8080 host is taken by Keycloak on this machine — using 8090)
PORT=8090
